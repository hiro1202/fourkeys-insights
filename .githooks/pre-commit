#!/bin/sh
# Pre-commit hook: format check, vet, and test

set -e

echo "==> Running pre-commit checks..."

# Backend checks (only if Go files changed)
if git diff --cached --name-only | grep -q '\.go$'; then
  echo "==> Go: format check"
  cd backend
  unformatted=$(gofmt -l .)
  if [ -n "$unformatted" ]; then
    echo "ERROR: Files not formatted with gofmt:"
    echo "$unformatted"
    echo "Run: cd backend && gofmt -w ."
    exit 1
  fi

  echo "==> Go: vet"
  go vet ./...

  echo "==> Go: test"
  CGO_ENABLED=1 go test ./... -short
  cd ..
fi

# Frontend checks (only if TS/TSX/JSON files changed)
if git diff --cached --name-only | grep -qE '\.(ts|tsx|json)$'; then
  if [ -d "frontend/node_modules" ]; then
    echo "==> Frontend: TypeScript check"
    cd frontend
    npx tsc --noEmit

    echo "==> Frontend: i18n check"
    node scripts/check-i18n.js
    cd ..
  fi
fi

echo "==> All checks passed"
